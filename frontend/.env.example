# ─── Backend API (Laravel on VPS) ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.bagroulette.xyz

# ─── WebSocket (Laravel Reverb on VPS) ───────────────────────────────────────
NEXT_PUBLIC_WS_URL=wss://api.bagroulette.xyz

# ─── Solana ───────────────────────────────────────────────────────────────────
# Get from https://helius.dev (free tier available)
NEXT_PUBLIC_SOLANA_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Your BagRoulette token mint address on Solana
NEXT_PUBLIC_TOKEN_MINT=YOUR_TOKEN_MINT_ADDRESS
